@page "/blog"
@inject AppDb Db
@implements IDisposable

<PageTitle>Blog Posts</PageTitle>

<h1>Blog Posts</h1>

<div class="mb-3 d-flex gap-2 align-items-center">
    <input class="form-control w-50" placeholder="Full-text search posts…" @bind="_searchTerm" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
    <button class="btn btn-primary" @onclick="LoadAsync">Refresh</button>
    <button class="btn btn-success" @onclick="OpenAddModal">+ New Post</button>
    <button class="btn btn-warning" @onclick="SeedAsync">Seed demo data</button>
</div>
<p class="text-muted small">Full-text search uses tokenised multi-entry IndexedDB indexes — no full table scan.</p>

@if (_loading)
{
    <p><em>Loading…</em></p>
}
else if (!_posts.Any())
{
    <p>No posts found. Click <strong>Seed demo data</strong> or write the first post!</p>
}
else
{
    @foreach (var post in _posts)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between">
                <strong>@post.Title</strong>
                <span class="text-muted small">@post.PublishedAt.ToString("d")</span>
            </div>
            <div class="card-body">
                <p>@post.Body</p>
                @if (post.Tags?.Length > 0)
                {
                    <p>
                        @foreach (var t in post.Tags)
                        {
                            <span class="badge bg-secondary me-1">@t</span>
                        }
                    </p>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                <button class="btn btn-sm btn-secondary" @onclick="() => OpenEditModal(post)">Edit</button>
                <button class="btn btn-sm btn-danger" @onclick="() => DeleteAsync(post.Id)">Delete</button>
            </div>
        </div>
    }
    <p class="text-muted">Showing @_posts.Count of @_totalCount posts</p>
}

@if (_showModal)
{
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@( _editing ? "Edit post" : "New post" )</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label>Title</label>
                        <input class="form-control" @bind="_form.Title" />
                    </div>
                    <div class="mb-2">
                        <label>Author</label>
                        <input class="form-control" @bind="_form.Author" />
                    </div>
                    <div class="mb-2">
                        <label>Body</label>
                        <textarea class="form-control" rows="6" @bind="_form.Body"></textarea>
                    </div>
                    <div class="mb-2">
                        <label>Tags (comma-separated)</label>
                        <input class="form-control" @bind="_tagsInput" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveAsync">Save</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger mt-2">@_error</div>
}

@code {
    private List<BlogPost> _posts = new();
    private int _totalCount;
    private bool _loading = true;
    private bool _showModal;
    private bool _editing;
    private string _searchTerm = string.Empty;
    private string _tagsInput = string.Empty;
    private string _error = string.Empty;
    private BlogPost _form = new();
    private IDisposable? _liveSubscription;

    protected override async Task OnInitializedAsync()
    {
        await Db.EnsureInitializedAsync();
        await LoadAsync();

        // LiveQuery re-renders the list whenever the store changes
        _liveSubscription = Db.BlogPosts
            .LiveQuery()
            .Subscribe(items =>
            {
                _posts = items.OrderByDescending(p => p.PublishedAt).ToList();
                _totalCount = _posts.Count;
                InvokeAsync(StateHasChanged);
            });
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = string.Empty;
        try
        {
            if (!string.IsNullOrWhiteSpace(_searchTerm))
            {
                // Full-text search — maps to multi-entry IDB index lookup, not a full scan
                _posts = (await Db.BlogPosts.Search(_searchTerm).ToListAsync())
                    .OrderByDescending(p => p.PublishedAt).ToList();
            }
            else
            {
                _posts = (await Db.BlogPosts.ToListAsync())
                    .OrderByDescending(p => p.PublishedAt).ToList();
            }
            _totalCount = await Db.BlogPosts.CountAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        _loading = false;
    }

    private async Task SeedAsync()
    {
        try
        {
            var now = DateTime.UtcNow;
            await Db.BlogPosts.AddAsync(new BlogPost
            {
                Id = Guid.NewGuid().ToString(),
                Title = "Getting started with BlazorIdb",
                Author = "Alice",
                Body = "BlazorIdb brings an EF Core-style developer experience to browser IndexedDB storage inside Blazor apps.",
                PublishedAt = now.AddDays(-5),
                Tags = new[] { "blazor", "indexeddb", "tutorial" }
            });
            await Db.BlogPosts.AddAsync(new BlogPost
            {
                Id = Guid.NewGuid().ToString(),
                Title = "Full-text search without a server",
                Author = "Bob",
                Body = "Multi-entry indexes in IndexedDB let you build fast full-text search entirely in the browser with zero network overhead.",
                PublishedAt = now.AddDays(-2),
                Tags = new[] { "search", "performance", "indexeddb" }
            });
            await Db.BlogPosts.AddAsync(new BlogPost
            {
                Id = Guid.NewGuid().ToString(),
                Title = "Blazor reactive updates with LiveQuery",
                Author = "Alice",
                Body = "The LiveQuery API returns an IObservable that re-emits whenever the underlying IndexedDB store changes, enabling reactive UI updates.",
                PublishedAt = now,
                Tags = new[] { "blazor", "reactive", "livequery" }
            });
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task DeleteAsync(string id)
    {
        try
        {
            await Db.BlogPosts.DeleteAsync(id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            _form.Tags = _tagsInput.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            if (_editing)
                await Db.BlogPosts.UpdateAsync(_form);
            else
            {
                if (string.IsNullOrWhiteSpace(_form.Id))
                    _form.Id = Guid.NewGuid().ToString();
                _form.PublishedAt = DateTime.UtcNow;
                await Db.BlogPosts.AddAsync(_form);
            }
            CloseModal();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void OpenAddModal()
    {
        _form = new BlogPost { Id = Guid.NewGuid().ToString() };
        _tagsInput = string.Empty;
        _editing = false;
        _showModal = true;
    }

    private void OpenEditModal(BlogPost p)
    {
        _form = new BlogPost
        {
            Id = p.Id, Title = p.Title, Author = p.Author,
            Body = p.Body, PublishedAt = p.PublishedAt, Tags = p.Tags
        };
        _tagsInput = p.Tags != null ? string.Join(", ", p.Tags) : string.Empty;
        _editing = true;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task OnSearchKeyUp() => await LoadAsync();

    public void Dispose() => _liveSubscription?.Dispose();
}
